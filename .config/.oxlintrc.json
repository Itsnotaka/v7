{
  "$schema": "../node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["node_modules", "dist", "next-env.d.ts", ".turbo"],
  "plugins": ["react", "nextjs", "import", "oxc", "react-perf", "typescript"],
  "settings": {
    "next": {
      "rootDir": ["apps/web"]
    }
  },
  "env": {
    "builtin": true
  }
}
